{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Details of a student or fan in the Academy",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "fan", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "role", "createdAt"]
    },
    "Lesson": {
      "title": "Academy Lesson",
      "description": "Educational content about the process of drawing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "level": { "type": "string", "enum": ["beginner", "intermediate", "expert"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "level", "createdAt"]
    },
    "ChatMessage": {
      "title": "Community Message",
      "description": "Real-time communication between students and the master",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Academy curriculum"
    },
    "/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Real-time community chat"
    }
  }
}
